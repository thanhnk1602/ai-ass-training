{
  "_comment": "Add these to your Claude Code MCP settings or ~/.claude/settings.json",

  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<your-github-token>"
      }
    },

    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/account_system"
      ]
    },

    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/narx/Source/ai-proj"
      ]
    },

    "demo-tools": {
      "command": "python",
      "args": ["/Users/narx/Source/ai-proj/training/level-04-mcp/samples/mcp-weather-server/server.py"]
    }
  }
}
